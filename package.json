{
  "name": "mergechain",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "MergeChain — a Chrome extension that adds merge dependencies to GitHub pull requests: block a PR's merge until the PRs it depends on land.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../mergechain.zip . -x '*.map' && cd .."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "eslint-plugin-functional": "^7.1.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.4"
  }
}
